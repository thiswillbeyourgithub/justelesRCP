# justelesRCP - static file server, no TLS in-container (front it with your proxy).
:8459 {
	encode zstd gzip

	# Runtime app config (window.__APP_CONFIG__) is rendered from the container
	# environment (ANALYTICS_* + DEV from docker/.env, STARTED_AT stamped at start)
	# by docker/entrypoint.sh into /gen, a writable tmpfs, at container start;
	# serve THAT for /app-config.js instead of the static local-dev fallback baked
	# into /srv. Rendering once at startup (not templating per request) means Caddy
	# never parses the JS as a Go template. The file is named generically, not
	# "analytics-*", so content filters that block "analytics" paths don't 404 it.
	handle /app-config.js {
		root * /gen
		file_server
	}

	# On-demand RCP refresh API -> the companion service container (refresh-service.py
	# on :8460, not published to the host). Same-origin, so the strict `connect-src
	# 'self'` CSP below covers the fetch()es from app-init.js. If the refresh service
	# is not running, this upstream is simply unreachable and /api/* returns 502; the
	# frontend degrades gracefully (the button reports it unavailable). Static-only
	# deploys can leave the refresh service out entirely.
	handle /api/* {
		reverse_proxy refresh:8460
	}

	# Everything else: the generated static site, bind-mounted read-only at /srv.
	handle {
		root * /srv
		# Serve precompressed .br/.gz siblings when the client supports them
		# (zero runtime CPU). Falls back to on-the-fly encode above.
		file_server {
			precompressed br gzip
			# Build-internal caches (written into dist by build.py): the
			# incremental-build manifest and the baseline RCP-presence cache.
			# Never expose them over HTTP.
			hide .build-manifest.json
			hide .rcp-present.json
		}
		# Pretty RCP URLs are stored as .html files.
		try_files {path} {path}.html {path}/index.html
	}

	# The self-hosted semantic-search assets (transformers.js + the ONNX encoder and
	# model, ~120 MB) live under /vendor and /models. They are versioned by
	# download-model.sh (a new version = a new build that changes the referencing
	# code), so they are safe to cache hard; everything else stays no-cache so a
	# redeploy shows up immediately (see the Cache-Control note below).
	@immutable path /vendor/* /models/*
	@volatile not path /vendor/* /models/*

	header {
		X-Content-Type-Options "nosniff"
		Referrer-Policy "no-referrer"
		# The only optional third-party origin is the umami tracker, whose origin
		# docker/entrypoint.sh derives from ANALYTICS_URL into ANALYTICS_ORIGIN
		# (empty when analytics is off, leaving the CSP with no extra origin).
		# script-src allows loading the tracker; connect-src allows its beacon.
		# 'wasm-unsafe-eval' lets the client-side semantic-search encoder instantiate
		# its WebAssembly (transformers.js + onnxruntime-web); it does NOT enable
		# JS eval() and is scoped to script-src only. Everything else stays self-only.
		Content-Security-Policy "default-src 'self'; img-src 'self' data:; style-src 'self'; script-src 'self' 'wasm-unsafe-eval' {$ANALYTICS_ORIGIN:}; connect-src 'self' {$ANALYTICS_ORIGIN:}; base-uri 'none'; frame-ancestors 'none'"
		-Server
	}
	# Always revalidate so a redeploy is picked up immediately. This is an early
	# prototype under active (re)deploys, so freshness beats cache hit-rate.
	# "no-cache" still STORES the response but forces a conditional request on
	# every use; Caddy's file_server answers 304 when nothing changed (so it
	# stays fast) and serves the new bytes right after a deploy. This is the fix
	# for "I still see the old UI after reloading": the previous long-lived
	# max-age=86400 on .css/.js let stale assets live in the browser for up to a
	# day, so a soft reload kept showing the old UI. (An upstream reverse proxy
	# or CDN in front of :8459 could still cache; make sure it honors no-cache.)
	# The immutable /vendor + /models assets are the sole exception (opt out of the
	# revalidate-every-time rule so a returning reader doesn't refetch the ~120 MB).
	header @volatile Cache-Control "no-cache"
	header @immutable Cache-Control "public, max-age=31536000, immutable"

	log {
		output stdout
		format console
	}
}
