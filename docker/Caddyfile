# justelesRCP - static file server, no TLS in-container (front it with your proxy).
{
	# rate_limit is from the caddy-ratelimit plugin, baked into the custom image
	# (docker/web.Dockerfile) since the stock caddy:2-alpine has no such module. It
	# is not a standard directive, so declare where it runs in the handler chain:
	# just before the proxy, so a flood is rejected before we dial the upstream.
	order rate_limit before reverse_proxy

	# Per-IP rate limiting needs the real visitor IP, but requests reach Caddy via
	# your upstream TLS proxy, so Caddy's immediate peer is that proxy, not the
	# visitor. Trust the proxy and read X-Forwarded-For to recover the client IP
	# ({http.request.client_ip}). `private_ranges` trusts loopback + RFC1918 peers,
	# the usual case (the proxy runs on the same host / docker network). If your
	# proxy sits on a PUBLIC IP, set TRUSTED_PROXIES to its address/CIDR in
	# docker/.env, else client_ip falls back to the proxy IP and the per-IP limit
	# collapses to a single global bucket.
	servers {
		trusted_proxies static {$TRUSTED_PROXIES:private_ranges}
	}
}

:8459 {
	encode zstd gzip

	# Runtime app config (window.__APP_CONFIG__) is rendered from the container
	# environment (ANALYTICS_* + DEV from docker/.env, STARTED_AT stamped at start)
	# by docker/entrypoint.sh into /gen, a writable tmpfs, at container start;
	# serve THAT for /app-config.js instead of the static local-dev fallback baked
	# into /srv. Rendering once at startup (not templating per request) means Caddy
	# never parses the JS as a Go template. The file is named generically, not
	# "analytics-*", so content filters that block "analytics" paths don't 404 it.
	handle /app-config.js {
		root * /gen
		file_server
	}

	# The DETAILED stats endpoints (raw queue internals, server RAM figures) are not
	# used by the site frontend and would reveal the scraping infra's shape / host
	# memory, so they are not exposed publicly: reach them from inside the docker
	# network or via `docker exec`. Exact-path `handle`s before the wildcards below,
	# and `handle` is first-match, so these win over /api/sem/* and /api/*. The PUBLIC
	# /status page instead consumes the curated /api/summary + /api/sem/summary
	# endpoints (progress %, counts, ETA; no host internals), which fall through to the
	# wildcard proxies below like any other API call and are rate-limited the same way.
	handle /api/stats {
		respond 404
	}
	handle /api/sem/stats {
		respond 404
	}

	# Per-drug semantic-search API -> the embed service container (embed-service.py
	# on :8461, not published to the host). MORE SPECIFIC than /api/* below, so it
	# must come first. Same-origin: the query POST (/api/sem/embed) is covered by the
	# strict `connect-src 'self'` CSP. If the embed service is absent, this 502s and
	# the search box degrades to an "indisponible" note (the encoder model is no
	# longer shipped to the browser, so nothing else regresses).
	handle /api/sem/* {
		# Cap the request body at the edge so a giant POST never reaches the small
		# Python service (the query endpoint also caps internally at 8 KiB).
		request_body {
			max_size 16KB
		}
		# Per-IP rate limit (caddy-ratelimit). A semantic-search session sends a
		# burst (page embed + status polls + one debounced embed per keystroke), so
		# the window is deliberately generous: it only stops a crude flood, while the
		# embed service's own concurrency semaphore bounds CPU. Tune via
		# SEM_RATE_EVENTS / SEM_RATE_WINDOW in docker/.env.
		rate_limit {
			zone sem {
				key {http.request.client_ip}
				events {$SEM_RATE_EVENTS:120}
				window {$SEM_RATE_WINDOW:1m}
			}
		}
		reverse_proxy embed:8461
	}

	# On-demand RCP refresh API -> the companion service container (refresh-service.py
	# on :8460, not published to the host). Same-origin, so the strict `connect-src
	# 'self'` CSP below covers the fetch()es from app-init.js. If the refresh service
	# is not running, this upstream is simply unreachable and /api/* returns 502; the
	# frontend degrades gracefully (the button reports it unavailable). Static-only
	# deploys can leave the refresh service out entirely.
	handle /api/* {
		# Cap the request body at the edge (the refresh POSTs carry no body).
		request_body {
			max_size 16KB
		}
		# Per-IP rate limit on the scraping API: a refresh POST triggers an outbound
		# ANSM/EMA fetch, so cap how fast any one client can drive it. The window
		# allows the status-poll burst after a refresh; the refresh service ALSO
		# enforces a global hourly scrape ceiling (REFRESH_DEMAND_HOURLY_MAX) that
		# bounds the aggregate no matter how the traffic is spread across IPs. Tune
		# via API_RATE_EVENTS / API_RATE_WINDOW in docker/.env.
		rate_limit {
			zone api {
				key {http.request.client_ip}
				events {$API_RATE_EVENTS:120}
				window {$API_RATE_WINDOW:1m}
			}
		}
		reverse_proxy refresh:8460
	}

	# Everything else: the generated static site, bind-mounted read-only at /srv.
	handle {
		root * /srv
		# Serve precompressed .br/.gz siblings when the client supports them
		# (zero runtime CPU). Falls back to on-the-fly encode above.
		file_server {
			precompressed br gzip
			# Build-internal caches (written into dist by build.py): the
			# incremental-build manifest and the baseline RCP-presence cache.
			# Never expose them over HTTP.
			hide .build-manifest.json
			hide .rcp-present.json
		}
		# Pretty RCP URLs are stored as .html files.
		try_files {path} {path}.html {path}/index.html
	}

	header {
		X-Content-Type-Options "nosniff"
		Referrer-Policy "no-referrer"
		# The only optional third-party origin is the umami tracker, whose origin
		# docker/entrypoint.sh derives from ANALYTICS_URL into ANALYTICS_ORIGIN
		# (empty when analytics is off, leaving the CSP with no extra origin).
		# script-src allows loading the tracker; connect-src allows its beacon.
		# The semantic-search encoder now runs SERVER-SIDE (embed-service.py), so the
		# browser no longer instantiates any WebAssembly: the previous
		# 'wasm-unsafe-eval' relaxation is gone and the query POST to /api/sem/embed
		# is same-origin, covered by connect-src 'self'. Everything stays self-only.
		Content-Security-Policy "default-src 'self'; img-src 'self' data:; style-src 'self'; script-src 'self' {$ANALYTICS_ORIGIN:}; connect-src 'self' {$ANALYTICS_ORIGIN:}; base-uri 'none'; frame-ancestors 'none'"
		-Server
	}
	# Always revalidate so a redeploy is picked up immediately. This is an early
	# prototype under active (re)deploys, so freshness beats cache hit-rate.
	# "no-cache" still STORES the response but forces a conditional request on
	# every use; Caddy's file_server answers 304 when nothing changed (so it
	# stays fast) and serves the new bytes right after a deploy. This is the fix
	# for "I still see the old UI after reloading": the previous long-lived
	# max-age=86400 on .css/.js let stale assets live in the browser for up to a
	# day, so a soft reload kept showing the old UI. (An upstream reverse proxy
	# or CDN in front of :8459 could still cache; make sure it honors no-cache.)
	# The old immutable /vendor + /models exception is gone: the ~120 MB encoder
	# model is no longer served to browsers (it runs in the embed container).
	header Cache-Control "no-cache"

	log {
		output stdout
		format console
	}
}
