# justelesRCP - static file server, no TLS in-container (front it with your proxy).
:8459 {
	encode zstd gzip

	# Runtime app config (window.__APP_CONFIG__) is rendered from the container
	# environment (ANALYTICS_* + DEV from docker/.env, STARTED_AT stamped at start)
	# by docker/entrypoint.sh into /gen, a writable tmpfs, at container start;
	# serve THAT for /app-config.js instead of the static local-dev fallback baked
	# into /srv. Rendering once at startup (not templating per request) means Caddy
	# never parses the JS as a Go template. The file is named generically, not
	# "analytics-*", so content filters that block "analytics" paths don't 404 it.
	handle /app-config.js {
		root * /gen
		file_server
	}

	# Everything else: the generated static site, bind-mounted read-only at /srv.
	handle {
		root * /srv
		# Serve precompressed .br/.gz siblings when the client supports them
		# (zero runtime CPU). Falls back to on-the-fly encode above.
		file_server {
			precompressed br gzip
		}
		# Pretty RCP URLs are stored as .html files.
		try_files {path} {path}.html {path}/index.html
	}

	# Long-lived caching for immutable assets; RCP content is regenerated by rebuild.
	# /app-config.js is excluded: it is per-deploy runtime config, so it must revalidate.
	@assets {
		path *.css *.js *.json
		not path /app-config.js
	}
	header @assets Cache-Control "public, max-age=86400"
	@appconfig path /app-config.js
	header @appconfig Cache-Control "no-cache"
	@pages path /rcp/*
	header @pages Cache-Control "public, max-age=3600"

	header {
		X-Content-Type-Options "nosniff"
		Referrer-Policy "no-referrer"
		# The only optional third-party origin is the umami tracker, whose origin
		# docker/entrypoint.sh derives from ANALYTICS_URL into ANALYTICS_ORIGIN
		# (empty when analytics is off, leaving the CSP with no extra origin).
		# script-src allows loading the tracker; connect-src allows its beacon.
		Content-Security-Policy "default-src 'self'; img-src 'self' data:; style-src 'self'; script-src 'self' {$ANALYTICS_ORIGIN:}; connect-src 'self' {$ANALYTICS_ORIGIN:}; base-uri 'none'; frame-ancestors 'none'"
		-Server
	}

	log {
		output stdout
		format console
	}
}
