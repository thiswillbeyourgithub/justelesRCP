# Copy this file to docker/.env and fill in the values you want.
# docker/.env is gitignored (it holds your real analytics ids); this template is
# the committed documentation. The compose file loads docker/.env via env_file,
# and docker/entrypoint.sh renders the values into /app-config.js at startup.
#
# Everything here is OPTIONAL: leave a value empty to disable that feature. With
# an empty file (or no analytics keys) the site serves exactly as before, with no
# tracking and no banner.

# --- Privacy-friendly umami analytics (page views + click events) ------------
# Injected at runtime into every page (src/app-init.js).
#
# ANALYTICS_URL         full URL of the umami tracking SCRIPT (used verbatim as
#                       <script src>), e.g. https://umami.example.com/script.js
#                       -- NOT the instance base URL. When set, the container
#                       validates it at startup (must be reachable AND serve
#                       JavaScript) and refuses to start otherwise; see
#                       docker/entrypoint.sh.
# ANALYTICS_WEBSITE_ID  umami website id (a UUID).
# ANALYTICS_SRI         optional Subresource Integrity hash for the script,
#                       e.g. sha384-... (umami must send CORS headers).
# ANALYTICS_DNT         umami "data-do-not-track" value. "true" (the default)
#                       respects the browser Do Not Track signal (those visitors
#                       are not tracked); "false" tracks everyone.
ANALYTICS_URL=
ANALYTICS_WEBSITE_ID=
ANALYTICS_SRI=
ANALYTICS_DNT=true

# --- DEV banner --------------------------------------------------------------
# DEV=1 shows a "site en cours de développement / dernier redémarrage il y a X"
# banner across the top of every page (src/dev-banner.js). Defaults to 0 (off).
# "il y a X" uses the container start time, stamped automatically at startup.
DEV=0

# SOURCE_URL: where the "Code source" link in the DEV banner points. Leave empty
# to hide the link. Set it to your public site or code repository.
SOURCE_URL=

# --- Edge rate limiting for the /api/* scraping endpoints (Caddy) ------------
# Read by Caddy in the web container (docker/Caddyfile). The web image is built
# with the caddy-ratelimit plugin (docker/web.Dockerfile), so /api/* and
# /api/sem/* are per-IP rate limited at the edge. These complement the refresh
# service's global hourly scrape ceiling (REFRESH_DEMAND_HOURLY_MAX below): the
# ceiling caps the aggregate, these cap any single client.
#
# TRUSTED_PROXIES: which upstream peers Caddy trusts to have set X-Forwarded-For,
#   so it can recover the real visitor IP ({http.request.client_ip}) for per-IP
#   limiting. Requests reach Caddy via your upstream TLS proxy, so its IP must be
#   trusted. Default "private_ranges" (loopback + RFC1918) covers a proxy on the
#   same host / docker network. If your proxy is on a PUBLIC IP, set this to its
#   address/CIDR (space-separated for several), else the per-IP limit degrades to
#   one global bucket keyed on the proxy IP.
TRUSTED_PROXIES=private_ranges
# API_RATE_EVENTS / API_RATE_WINDOW: per-IP allowance for /api/* (the refresh +
#   status-poll endpoints). A refresh POST triggers an outbound ANSM/EMA fetch; the
#   window is generous enough for the ~1/s status polling that follows a refresh.
#   Default 120 events / 1m. Over the limit, Caddy returns 429.
API_RATE_EVENTS=120
API_RATE_WINDOW=1m
# SEM_RATE_EVENTS / SEM_RATE_WINDOW: per-IP allowance for /api/sem/* (semantic
#   search). A search session bursts (page embed + polls + one debounced embed per
#   keystroke), so keep it generous. Default 120 events / 1m.
SEM_RATE_EVENTS=120
SEM_RATE_WINDOW=1m

# --- On-demand refresh service (refresh-service.py) --------------------------
# The companion container behind the "Rafraichir maintenant" button and the
# >1-year auto-refresh. All OPTIONAL; the defaults are sane. Leave this whole
# section out if you run a static-only deploy without the refresh service.
#
# REFRESH_UID / REFRESH_GID: the host user/group that owns ../data and ../dist.
#   compose runs the service as this uid:gid so the overlays, rebuilt pages and
#   manifest it writes stay owned by you (and sync cleanly). Defaults to 1000
#   (the usual first Linux user); set these if your host uid differs (e.g. VPS).
#   NOTE: these are used by compose's `user:` interpolation (read from this file
#   because the compose project dir is docker/); they are also injected into the
#   container but the service ignores them.
REFRESH_UID=1000
REFRESH_GID=1000
#
# REFRESH_RATE_SECONDS: base seconds between outbound ANSM fetches on the CRAWLER
#   lane (a random 0..min(rate,10)s jitter is added). Default 120 (~2 min), a gentle
#   background trickle. On-demand button/auto clicks run on their OWN faster lane
#   (REFRESH_DEMAND_RATE_SECONDS) so they no longer wait behind this gap.
REFRESH_RATE_SECONDS=120
# REFRESH_DEMAND_RATE_SECONDS: base seconds between outbound ANSM fetches on the
#   ON-DEMAND lane (button + >1yr auto-refresh), decoupled from the crawler so a
#   click is scraped almost at once instead of waiting up to one crawler gap. A lone
#   click after an idle period fetches immediately; this only spaces out bursts of
#   distinct pages. Default 5. Keep it small but non-zero to stay polite to ANSM.
REFRESH_DEMAND_RATE_SECONDS=5
# REFRESH_MIN_INTERVAL_SECONDS: per-drug anti-hammer floor. A drug refreshed more
#   recently than this is reported "already fresh" without re-fetching, so repeat
#   clicks and many visitors on the same stale page collapse to one fetch.
#   Default 3600 (1h).
REFRESH_MIN_INTERVAL_SECONDS=3600
# REFRESH_QUEUE_MAX: max pending ON-DEMAND (button/auto) refreshes before further
#   requests get "busy". The crawler holds no queue, so this bounds clicks only.
#   Default 200.
REFRESH_QUEUE_MAX=200
# REFRESH_DEMAND_HOURLY_MAX: catalog-wide anti-amplification ceiling. The hard cap
#   on how many distinct ON-DEMAND (button/auto) outbound fetches the service will
#   start per rolling hour. The per-drug REFRESH_MIN_INTERVAL_SECONDS floor stops
#   hammering ONE drug; this stops anyone turning the service into a high-volume
#   ANSM/EMA scraper by enumerating CIS (which would make your IP look abusive to a
#   government site). Past it, requests get "busy" (retry later). The background
#   crawler is exempt (it is TTL-bounded and is the intended steady traffic).
#   Default 300 (generous for real use). Set 0 to disable the ceiling. This is a
#   global ceiling, complementary to the per-IP rate limit on /api/* at the proxy
#   (see docker/Caddyfile's rate_limit); keep both.
REFRESH_DEMAND_HOURLY_MAX=300
# REFRESH_CRAWL: run the perpetual background crawler that walks every page in
#   frequency (sold-units) order and refreshes any older than REFRESH_CRAWL_TTL_DAYS,
#   on its own slow REFRESH_RATE_SECONDS lane, then idles until the oldest one ages
#   past the TTL again. "1"/"true" on (default), "0"/"false" leaves only button/auto.
REFRESH_CRAWL=1
# REFRESH_CRAWL_TTL_DAYS: the crawler's staleness threshold. It keeps every page's
#   captured copy no older than this, sweeping the catalog then idling. Default 365
#   (~12 months, matching the >1-year auto-refresh line the site shows to readers).
REFRESH_CRAWL_TTL_DAYS=365
#
# --- EMA /eu/ lane (centrally-authorized drugs) ------------------------------
# A centrally-authorized drug has no ANSM RCP; its SmPC/notice lives in an EMA
# PDF, converted on-site to its /eu/ page. Both the "Rafraichir" button on a /eu/
# page and the /eu/ crawler go through a SEPARATE EMA lane with its OWN manifest
# (data/.scrape-ema-manifest.json). The EMA is strict about automated access, so
# this lane is deliberately slow.
# REFRESH_EMA_CRAWL: run the perpetual /eu/ crawler (like REFRESH_CRAWL but for the
#   EMA pages, on its own REFRESH_EMA_RATE_SECONDS lane). "1"/"true" on (default),
#   "0"/"false" leaves /eu/ pages to the on-demand button + manual scrape-ema.py.
REFRESH_EMA_CRAWL=1
# REFRESH_EMA_RATE_SECONDS: base seconds between outbound EMA fetches on the /eu/
#   crawler lane. Default 300 (~5 min), a gentle trickle (the EMA is strict).
REFRESH_EMA_RATE_SECONDS=300
# REFRESH_EMA_CRAWL_TTL_DAYS: staleness threshold for the /eu/ crawler. Default 180
#   (~6 months); EMA SmPC PDFs change rarely, so a long window keeps EMA traffic low.
REFRESH_EMA_CRAWL_TTL_DAYS=180
# REFRESH_LOG_LEVEL: minimum log level. Default INFO keeps the per-request DEBUG
#   chatter (status polls, refresh POSTs) out of the logs and shows the crawl
#   stats; the /api/health check is never logged. Set DEBUG to troubleshoot.
REFRESH_LOG_LEVEL=INFO
# EMBED_NOTIFY_URL: after a fresh overlay lands, refresh-service.py pings the embed
#   service here so it re-embeds that page for semantic search (best-effort, content-
#   hash gated on the embed side, swallowed on failure). Default http://embed:8461
#   (the compose service name). Leave EMPTY to disable the ping (the embed service's
#   own reconcile sweep is the backstop). Cross-service: read on the REFRESH side.
EMBED_NOTIFY_URL=http://embed:8461
# RCP_OVERLAY_GZIP: store overlays gzip-compressed (matches scrape-rcp.py's
#   default). "1"/"true" on (default), "0"/"false" for plain HTML. build.py reads
#   either transparently.
RCP_OVERLAY_GZIP=1

# --- Server-side semantic-search embedder (embed-service.py) -----------------
# The warm compute container behind the per-drug "Rechercher dans ce RCP" box: it
# embeds the reader's query on request (POST /api/sem/embed, no browser model) and
# (re-)embeds each CRAWLED page's sections in the background, writing the served
# dist/<rcp|eu>/<slug>.vec.json (never the frozen 2022 baseline). All OPTIONAL with
# sane defaults; leave this section out for a static-only or refresh-only deploy and
# the search box degrades to "indisponible".
#
# EMBED_UID / EMBED_GID: the host user/group that owns ../dist, so the .vec.json
#   files the service writes stay owned by you (same rationale as REFRESH_UID/GID).
#   Used by compose's `user:` interpolation. Default 1000.
EMBED_UID=1000
EMBED_GID=1000
# EMBED_ENABLE: run the background reconcile sweep that (re-)embeds crawled pages
#   as their overlays change (in addition to the refresh ping and the on-demand
#   button). "1"/"true" on (default), "0"/"false" leaves ONLY on-demand + ping.
EMBED_ENABLE=1
# EMBED_INTRA_THREADS: onnxruntime intra-op threads for the encode. A positive value is
#   a literal thread count; <= 0 is relative to the CPU count (-1 = all cores, -2 = all
#   but one, floored at 1, respecting the container's cpuset). Default -2 uses all cores
#   but one to speed the background sweep while leaving headroom; a query is ~15 ms even
#   single-threaded. Set a small positive value (e.g. 2) to cap it on a shared VPS.
EMBED_INTRA_THREADS=-2
# EMBED_BACKLOG_RATE_SECONDS: seconds to pause after each background (sweep) page.
#   Default 0 = no pause, so the catalog indexes as fast as the CPU allows; on-demand
#   queries still jump the queue and are never throttled. Raise it (e.g. 2) to yield CPU
#   on a box that also serves a lot of live search traffic during the initial sweep.
EMBED_BACKLOG_RATE_SECONDS=0.0
# EMBED_RECONCILE_SECONDS: how often the service re-scans overlays for changes it
#   was not pinged about (a manual scrape-*.py run). Default 60.
EMBED_RECONCILE_SECONDS=60
# EMBED_QUEUE_MAX: max pending page embeds before new enqueues are shed as "busy".
#   Default 500.
EMBED_QUEUE_MAX=500
# EMBED_MAX_CONCURRENT_QUERIES: cap on query encodes running at once, so a flood of
#   /api/sem/embed POSTs can't pin every core (each runs on its own server thread). A
#   short wait absorbs normal bursts; past that a request is shed with 503. Default 8.
#   NOTE: this bounds CPU, not request RATE: per-IP/per-second rate limiting still
#   belongs at your upstream reverse proxy (the caddy:2-alpine image here has no
#   rate-limit module), which is also where to throttle /api/sem/page enumeration.
EMBED_MAX_CONCURRENT_QUERIES=8
# EMBED_MIN_QUERY_CHARS / EMBED_MAX_QUERY_CHARS: accepted query length band; outside
#   it POST /api/sem/embed returns 400. MIN must match the client gate in
#   src/rcp-semsearch.js (5). Defaults 5 / 400.
EMBED_MIN_QUERY_CHARS=5
EMBED_MAX_QUERY_CHARS=400
# EMBED_QUERY_CACHE: size of the in-process LRU of query-hash->vector, so repeated/edited
#   queries (common as the reader types) recompute nothing. Default 256.
EMBED_QUERY_CACHE=256
# EMBED_QUERY_CACHE_TTL_SECONDS: how long a cached query-hash->vector entry may live
#   before it is purged (lazily on access + swept by the reconcile loop). Bounds how
#   long any query-derived data (a hash key + lossy vector, never the plaintext) is
#   retained in memory. Default 60. Set 0 to disable expiry (LRU-only, entries linger
#   until evicted).
EMBED_QUERY_CACHE_TTL_SECONDS=60
# EMBED_MODEL_DIR: directory of the ONNX model + tokenizer inside the container.
#   Default /app/models/Snowflake/snowflake-arctic-embed-l-v2.0 (../models is mounted
#   read-only; run ./download-model.sh to populate it). Keep in sync with the model the
#   .vec.json vectors were baked with (onnx_embed.RUNTIME_MODEL).
EMBED_MODEL_DIR=/app/models/Snowflake/snowflake-arctic-embed-l-v2.0
# EMBED_OUT_DIM: Matryoshka (MRL) embedding width to truncate to. Default 256 (suits
#   arctic-embed-l-v2.0); 0 keeps the full model width. Changing it re-embeds the whole
#   catalog: the width is baked into each .vec.json and gated on, so the reader's query
#   vectors and the stored passage vectors always share one width (else cosine breaks).
#   Keep it aligned with EMBED_MODEL_DIR / onnx_embed.RUNTIME_MODEL.
EMBED_OUT_DIM=256
# EMBED_SEM_FLOOR: minimum raw cosine (-1..1) for a section to count as a search
#   candidate for the per-drug "Recherche sémantique dans ce RCP" box. The gate runs
#   client-side (ranking happens in the browser), so this value is handed to the browser
#   in every /api/sem/embed response; src/rcp-semsearch.js applies it. Default 0.0 keeps
#   every section (only the hybrid semantic+keyword rank and the result cap prune, so a
#   query always yields its closest passages). Raise it (e.g. 0.5, "at least 50 %
#   similarity") to drop weak matches and let a wholly-irrelevant query return nothing.
EMBED_SEM_FLOOR=0.0
# REFRESH_TRIGGER_URL: when a reader searches a page that was never crawled (only
#   the 2022 baseline exists), the embed service asks the refresh service HERE to
#   crawl it first, then embeds it. Default http://refresh:8460 (the compose service
#   name). Leave EMPTY to disable baseline auto-crawl (such pages stay unindexed).
#   Cross-service: read on the EMBED side.
REFRESH_TRIGGER_URL=http://refresh:8460
# EMBED_LOG_LEVEL: minimum log level. Default INFO; /api/sem/health is never logged.
#   Query CONTENT is never logged at any level (privacy). Set DEBUG to troubleshoot.
EMBED_LOG_LEVEL=INFO
