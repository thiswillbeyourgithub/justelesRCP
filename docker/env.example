# Copy this file to docker/.env and fill in the values you want.
# docker/.env is gitignored (it holds your real analytics ids); this template is
# the committed documentation. The compose file loads docker/.env via env_file,
# and docker/entrypoint.sh renders the values into /app-config.js at startup.
#
# Everything here is OPTIONAL: leave a value empty to disable that feature. With
# an empty file (or no analytics keys) the site serves exactly as before, with no
# tracking and no banner.

# --- Privacy-friendly umami analytics (page views + click events) ------------
# Injected at runtime into every page (src/app-init.js).
#
# ANALYTICS_URL         full URL of the umami tracking SCRIPT (used verbatim as
#                       <script src>), e.g. https://umami.example.com/script.js
#                       -- NOT the instance base URL. When set, the container
#                       validates it at startup (must be reachable AND serve
#                       JavaScript) and refuses to start otherwise; see
#                       docker/entrypoint.sh.
# ANALYTICS_WEBSITE_ID  umami website id (a UUID).
# ANALYTICS_SRI         optional Subresource Integrity hash for the script,
#                       e.g. sha384-... (umami must send CORS headers).
# ANALYTICS_DNT         umami "data-do-not-track" value. "true" (the default)
#                       respects the browser Do Not Track signal (those visitors
#                       are not tracked); "false" tracks everyone.
ANALYTICS_URL=
ANALYTICS_WEBSITE_ID=
ANALYTICS_SRI=
ANALYTICS_DNT=true

# --- DEV banner --------------------------------------------------------------
# DEV=1 shows a "site en cours de développement / dernier redémarrage il y a X"
# banner across the top of every page (src/dev-banner.js). Defaults to 0 (off).
# "il y a X" uses the container start time, stamped automatically at startup.
DEV=0

# SOURCE_URL: where the "Code source" link in the DEV banner points. Leave empty
# to hide the link. Set it to your public site or code repository.
SOURCE_URL=

# --- On-demand refresh service (refresh-service.py) --------------------------
# The companion container behind the "Rafraichir maintenant" button and the
# >1-year auto-refresh. All OPTIONAL; the defaults are sane. Leave this whole
# section out if you run a static-only deploy without the refresh service.
#
# REFRESH_UID / REFRESH_GID: the host user/group that owns ../data and ../dist.
#   compose runs the service as this uid:gid so the overlays, rebuilt pages and
#   manifest it writes stay owned by you (and sync cleanly). Defaults to 1000
#   (the usual first Linux user); set these if your host uid differs (e.g. VPS).
#   NOTE: these are used by compose's `user:` interpolation (read from this file
#   because the compose project dir is docker/); they are also injected into the
#   container but the service ignores them.
REFRESH_UID=1000
REFRESH_GID=1000
#
# REFRESH_RATE_SECONDS: base seconds between outbound ANSM fetches on the CRAWLER
#   lane (a random 0..min(rate,10)s jitter is added). Default 120 (~2 min), a gentle
#   background trickle. On-demand button/auto clicks run on their OWN faster lane
#   (REFRESH_DEMAND_RATE_SECONDS) so they no longer wait behind this gap.
REFRESH_RATE_SECONDS=120
# REFRESH_DEMAND_RATE_SECONDS: base seconds between outbound ANSM fetches on the
#   ON-DEMAND lane (button + >1yr auto-refresh), decoupled from the crawler so a
#   click is scraped almost at once instead of waiting up to one crawler gap. A lone
#   click after an idle period fetches immediately; this only spaces out bursts of
#   distinct pages. Default 5. Keep it small but non-zero to stay polite to ANSM.
REFRESH_DEMAND_RATE_SECONDS=5
# REFRESH_MIN_INTERVAL_SECONDS: per-drug anti-hammer floor. A drug refreshed more
#   recently than this is reported "already fresh" without re-fetching, so repeat
#   clicks and many visitors on the same stale page collapse to one fetch.
#   Default 3600 (1h).
REFRESH_MIN_INTERVAL_SECONDS=3600
# REFRESH_QUEUE_MAX: max pending ON-DEMAND (button/auto) refreshes before further
#   requests get "busy". The crawler holds no queue, so this bounds clicks only.
#   Default 200.
REFRESH_QUEUE_MAX=200
# REFRESH_CRAWL: run the perpetual background crawler that walks every page in
#   frequency (sold-units) order and refreshes any older than REFRESH_CRAWL_TTL_DAYS,
#   on its own slow REFRESH_RATE_SECONDS lane, then idles until the oldest one ages
#   past the TTL again. "1"/"true" on (default), "0"/"false" leaves only button/auto.
REFRESH_CRAWL=1
# REFRESH_CRAWL_TTL_DAYS: the crawler's staleness threshold. It keeps every page's
#   captured copy no older than this, sweeping the catalog then idling. Default 365
#   (~12 months, matching the >1-year auto-refresh line the site shows to readers).
REFRESH_CRAWL_TTL_DAYS=365
# REFRESH_LOG_LEVEL: minimum log level. Default INFO keeps the per-request DEBUG
#   chatter (status polls, refresh POSTs) out of the logs and shows the crawl
#   stats; the /api/health check is never logged. Set DEBUG to troubleshoot.
REFRESH_LOG_LEVEL=INFO
# RCP_OVERLAY_GZIP: store overlays gzip-compressed (matches scrape-rcp.py's
#   default). "1"/"true" on (default), "0"/"false" for plain HTML. build.py reads
#   either transparently.
RCP_OVERLAY_GZIP=1
