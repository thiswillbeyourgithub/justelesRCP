# justelesRCP - static file server, no TLS in-container (front it with your proxy).
:8080 {
	root * /srv
	encode zstd gzip

	# Serve precompressed .br/.gz siblings when the client supports them
	# (zero runtime CPU). Falls back to on-the-fly encode above.
	file_server {
		precompressed br gzip
	}

	# Pretty RCP URLs are stored as .html files.
	try_files {path} {path}.html {path}/index.html

	# Long-lived caching for immutable assets; RCP content is regenerated by rebuild.
	@assets path *.css *.js *.json
	header @assets Cache-Control "public, max-age=86400"
	@pages path /rcp/*
	header @pages Cache-Control "public, max-age=3600"

	header {
		X-Content-Type-Options "nosniff"
		Referrer-Policy "no-referrer"
		Content-Security-Policy "default-src 'self'; img-src 'self' data:; style-src 'self'; script-src 'self'; base-uri 'none'; frame-ancestors 'none'"
		-Server
	}

	log {
		output stdout
		format console
	}
}
